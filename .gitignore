# .NET / Avalonia & IDE specific gitignore
# ----------------------------------------
# Build results
[Bb]in/
[Oo]bj/
[Ll]og/

# Ignore outputs created by Publish.bat
bin/output/
/src/bin/
/src/obj/

# Visual Studio / Rider cache/options directory
.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# ReSharper / JetBrains
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
*.sln.iml

# Benchmark / Code Coverage Results
BenchmarkDotNet.Artifacts/
*.coverage
*.coveragexml

# Publish Output
*.[Pp]ublish.xml
*.publishproj

# NuGet / Packages
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# MSBuild Binary and Structured Log
*.binlog

# Mac / Windows system files
.DS_Store
Thumbs.db

# Claude Code
.claude/
dist/
