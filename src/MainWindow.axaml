<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:models="using:RightClickManager.Models"
		xmlns:vm="using:RightClickManager.ViewModels"
		xmlns:ui="using:FluentAvalonia.UI.Controls"
		xmlns:lottie="clr-namespace:Avalonia.Skia.Lottie;assembly=Avalonia.Skia.Lottie"
        x:Class="RightClickManager.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		TransparencyLevelHint="AcrylicBlur"
        Background="{DynamicResource MainWindowBackgroundBrush}"
		Width="600" Height="600"
		MinWidth="300" MinHeight="100"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Title="{DynamicResource LangText_AppTitle}"
        Icon="avares://RightClickManager/icon.ico"
		ExtendClientAreaToDecorationsHint="True">
	<Grid x:Name="LayoutRoot" IsEnabled="{Binding SearchCommand.IsRunning, Converter={StaticResource NotConverter}}"
		  RowDefinitions="40, Auto, *">
		<StackPanel Orientation="Horizontal" Margin="17,0" VerticalAlignment="Center">
			<TextBlock FontSize="12" Text="{DynamicResource LangText_AppTitle}" VerticalAlignment="Center" IsHitTestVisible="False" />
			<Menu Background="Transparent" Margin="8,0,0,0" Padding="0">
				<MenuItem Header="{DynamicResource LangText_Settings}" FontSize="12" Padding="4,2">
					<MenuItem Header="{DynamicResource LangText_AutoStart}" Command="{Binding ToggleAutoStartCommand}">
						<MenuItem.Icon>
							<TextBlock Text="✓" IsVisible="{Binding IsAutoStartEnabled}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem Header="{DynamicResource LangText_Language}">
						<MenuItem Header="{DynamicResource LangText_FollowSystem}" Command="{Binding SetLanguageCommand}" CommandParameter="system">
							<MenuItem.Icon>
								<TextBlock Text="✓" IsVisible="{Binding IsSystemLanguage}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
							</MenuItem.Icon>
						</MenuItem>
						<MenuItem Header="简体中文" Command="{Binding SetLanguageCommand}" CommandParameter="zh-CN">
							<MenuItem.Icon>
								<TextBlock Text="✓" IsVisible="{Binding IsChineseLanguage}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
							</MenuItem.Icon>
						</MenuItem>
						<MenuItem Header="English" Command="{Binding SetLanguageCommand}" CommandParameter="en-US">
							<MenuItem.Icon>
								<TextBlock Text="✓" IsVisible="{Binding IsEnglishLanguage}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
							</MenuItem.Icon>
						</MenuItem>
					</MenuItem>
				</MenuItem>
			</Menu>
		</StackPanel>
		<Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="16,4,16,12">
			<TextBox x:Name="SearchBox" Text="{Binding SearchingText,Mode=TwoWay}" Watermark="{DynamicResource LangText_SearchWatermark}" Margin="0,0,8,0" KeyDown="SearchBox_KeyDown" />
			<Button x:Name="SearchButton" Grid.Column="1" BorderThickness="0" VerticalAlignment="Stretch" VerticalContentAlignment="Center"
					Command="{Binding SearchCommand}" CommandParameter="{Binding SearchingText}">
				<Grid MinWidth="64">
					<TextBlock Text="{DynamicResource LangText_Search}" HorizontalAlignment="Center" IsVisible="{Binding SearchingText,Converter={StaticResource StringIsNotEmptyConverter}}" />
					<TextBlock Text="{DynamicResource LangText_Refresh}" HorizontalAlignment="Center" IsVisible="{Binding SearchingText,Converter={StaticResource StringIsEmptyConverter}}" />
				</Grid>
			</Button>
		</Grid>

		<Grid Grid.Row="2">
			<TabControl Margin="16,0,16,12">
			<!-- ════ Allowed Tab ════ -->
			<TabItem Header="{DynamicResource LangText_TabAllowed}">
				<ScrollViewer Focusable="True" FocusAdorner="{x:Null}">
					<StackPanel>
					<TextBlock Text="{DynamicResource LangText_AppItems}" FontSize="13" FontWeight="SemiBold" Margin="8,8,8,4" />
					<StackPanel>
						<!-- loading indicator 已移至 TabControl 外层浮动覆盖 -->
						<Border Background="#10000000" CornerRadius="4" Padding="24,20"
								IsVisible="{Binding Apps, Converter={StaticResource CollectionEmptyConverter}}">
							<TextBlock Text="{DynamicResource LangText_NoData}" Foreground="Gray" HorizontalAlignment="Center" />
						</Border>
						<ItemsControl ItemsSource="{Binding Apps}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="models:PackagedAppModel">
									<Expander HorizontalAlignment="Stretch" IsExpanded="True" Margin="0,4" Padding="0" CornerRadius="4">
										<Expander.Header>
											<Grid ColumnDefinitions="Auto,*,Auto" MinHeight="60">
												<Border ClipToBounds="True" Width="32" Height="32" Margin="0,0,12,0" CornerRadius="4" Background="{DynamicResource AppListIconBackgroundBrush}" VerticalAlignment="Center">
													<Image Source="{Binding Icon}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="Uniform" />
												</Border>
												<TextBlock Text="{Binding DisplayName}" FontSize="14" LineHeight="22" Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,4" />
												<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0,12,0">
<CheckBox IsThreeState="True" IsChecked="{Binding SelectAllState, Mode=OneWay}" Command="{Binding SelectAllCommand}" VerticalAlignment="Center" />
									<Button Content="{DynamicResource LangText_EnableSelected}" Command="{Binding EnableSelectedCommand}" />
									<Button Content="{DynamicResource LangText_DisableSelected}" Command="{Binding DisableSelectedCommand}" />
												</StackPanel>
											</Grid>
										</Expander.Header>
										<StackPanel>
											<ItemsControl ItemsSource="{Binding VisibleContextMenuItems}" Margin="60,8,12,8">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="models:ContextMenuItemCheckModel">
														<CheckBox Margin="0,4,0,4" IsChecked="{Binding Enabled,Mode=TwoWay}" IsEnabled="{Binding CanModify}">
															<CheckBox.ContextMenu>
																<ContextMenu>
																	<MenuItem Header="{DynamicResource LangText_OpenFileLocation}" Command="{Binding OpenFileLocationCommand}" IsEnabled="{Binding HasFilePath}" />
																</ContextMenu>
															</CheckBox.ContextMenu>
															<Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding DisplayName}" FontFamily="Consolas, Segoe UI" TextWrapping="Wrap" VerticalAlignment="Center" /><Border Grid.Column="1" Width="8" Height="8" CornerRadius="4" Background="{Binding StatusColor}" VerticalAlignment="Center" Margin="8,0,0,0" /></Grid>
														</CheckBox>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<Button HorizontalAlignment="Left" Margin="70,0,12,8"
													Command="{Binding ToggleItemsExpandCommand}" IsVisible="{Binding HasMoreItems}">
												<Grid>
													<TextBlock Text="{DynamicResource LangText_ShowMore}" IsVisible="{Binding IsItemsExpanded, Converter={StaticResource NotConverter}}" />
													<TextBlock Text="{DynamicResource LangText_ShowLess}" IsVisible="{Binding IsItemsExpanded}" />
												</Grid>
											</Button>
										</StackPanel>
									</Expander>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
					<TextBlock Text="{DynamicResource LangText_SystemItems}" FontSize="13" FontWeight="SemiBold" Margin="8,16,8,4" />
					<StackPanel>
						<!-- loading indicator 已移至 TabControl 外层浮动覆盖 -->
						<Border Background="#10000000" CornerRadius="4" Padding="24,20"
								IsVisible="{Binding SystemItems, Converter={StaticResource CollectionEmptyConverter}}">
							<TextBlock Text="{DynamicResource LangText_NoData}" Foreground="Gray" HorizontalAlignment="Center" />
						</Border>
						<ItemsControl ItemsSource="{Binding SystemItems}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="models:SystemShellGroup">
									<Expander HorizontalAlignment="Stretch" IsExpanded="True" Margin="0,4" Padding="0" CornerRadius="4">
										<Expander.Header>
											<Grid ColumnDefinitions="Auto,*,Auto" MinHeight="48">
												<TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0" />
												<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0,12,0">
<CheckBox IsThreeState="True" IsChecked="{Binding SelectAllState, Mode=OneWay}" Command="{Binding SelectAllCommand}" VerticalAlignment="Center" />
									<Button Content="{DynamicResource LangText_EnableSelected}" Command="{Binding EnableSelectedCommand}" />
									<Button Content="{DynamicResource LangText_DisableSelected}" Command="{Binding DisableSelectedCommand}" />
												</StackPanel>
											</Grid>
										</Expander.Header>
										<StackPanel>
											<ItemsControl ItemsSource="{Binding VisibleItems}" Margin="40,8,12,8">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="models:SystemShellItem">
														<CheckBox Margin="0,4,0,4" IsChecked="{Binding Enabled, Mode=TwoWay}" IsEnabled="{Binding CanModify}">
															<CheckBox.ContextMenu>
																<ContextMenu>
																	<MenuItem Header="{DynamicResource LangText_OpenFileLocation}" Command="{Binding OpenFileLocationCommand}" IsEnabled="{Binding HasFilePath}" />
																</ContextMenu>
															</CheckBox.ContextMenu>
															<Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding DisplayName}" FontFamily="Consolas, Segoe UI" TextWrapping="Wrap" VerticalAlignment="Center" /><Border Grid.Column="1" Width="8" Height="8" CornerRadius="4" Background="{Binding StatusColor}" VerticalAlignment="Center" Margin="8,0,0,0" /></Grid>
														</CheckBox>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<Button HorizontalAlignment="Left" Margin="50,0,12,8"
													Command="{Binding ToggleItemsExpandCommand}" IsVisible="{Binding HasMoreItems}">
												<Grid>
													<TextBlock Text="{DynamicResource LangText_ShowMore}" IsVisible="{Binding IsItemsExpanded, Converter={StaticResource NotConverter}}" />
													<TextBlock Text="{DynamicResource LangText_ShowLess}" IsVisible="{Binding IsItemsExpanded}" />
												</Grid>
											</Button>
										</StackPanel>
									</Expander>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
					</StackPanel>
				</ScrollViewer>
			</TabItem>

			<!-- ════ Disabled Tab ════ -->
			<TabItem Header="{DynamicResource LangText_TabDisabled}">
				<ScrollViewer Focusable="True" FocusAdorner="{x:Null}">
					<StackPanel>
					<TextBlock Text="{DynamicResource LangText_AppItems}" FontSize="13" FontWeight="SemiBold" Margin="8,8,8,4" />
					<StackPanel>
						<!-- loading indicator 已移至 TabControl 外层浮动覆盖 -->
						<Border Background="#10000000" CornerRadius="4" Padding="24,20"
								IsVisible="{Binding BlockedApps, Converter={StaticResource CollectionEmptyConverter}}">
							<TextBlock Text="{DynamicResource LangText_NoData}" Foreground="Gray" HorizontalAlignment="Center" />
						</Border>
						<ItemsControl ItemsSource="{Binding BlockedApps}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="models:PackagedAppModel">
									<Expander HorizontalAlignment="Stretch" IsExpanded="True" Margin="0,4" Padding="0" CornerRadius="4">
										<Expander.Header>
											<Grid ColumnDefinitions="Auto,*,Auto" MinHeight="60">
												<Border ClipToBounds="True" Width="32" Height="32" Margin="0,0,12,0" CornerRadius="4" Background="{DynamicResource AppListIconBackgroundBrush}" VerticalAlignment="Center">
													<Image Source="{Binding Icon}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="Uniform" />
												</Border>
												<TextBlock Text="{Binding DisplayName}" FontSize="14" LineHeight="22" Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,4" />
												<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0,12,0">
<CheckBox IsThreeState="True" IsChecked="{Binding SelectAllState, Mode=OneWay}" Command="{Binding SelectAllCommand}" VerticalAlignment="Center" />
									<Button Content="{DynamicResource LangText_EnableSelected}" Command="{Binding EnableSelectedCommand}" />
									<Button Content="{DynamicResource LangText_DisableSelected}" Command="{Binding DisableSelectedCommand}" />
												</StackPanel>
											</Grid>
										</Expander.Header>
										<StackPanel>
											<ItemsControl ItemsSource="{Binding VisibleContextMenuItems}" Margin="60,8,12,8">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="models:ContextMenuItemCheckModel">
														<CheckBox Margin="0,4,0,4" IsChecked="{Binding Enabled,Mode=TwoWay}" IsEnabled="{Binding CanModify}">
															<CheckBox.ContextMenu>
																<ContextMenu>
																	<MenuItem Header="{DynamicResource LangText_OpenFileLocation}" Command="{Binding OpenFileLocationCommand}" IsEnabled="{Binding HasFilePath}" />
																</ContextMenu>
															</CheckBox.ContextMenu>
															<Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding DisplayName}" FontFamily="Consolas, Segoe UI" TextWrapping="Wrap" VerticalAlignment="Center" /><Border Grid.Column="1" Width="8" Height="8" CornerRadius="4" Background="{Binding StatusColor}" VerticalAlignment="Center" Margin="8,0,0,0" /></Grid>
														</CheckBox>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<Button HorizontalAlignment="Left" Margin="70,0,12,8"
													Command="{Binding ToggleItemsExpandCommand}" IsVisible="{Binding HasMoreItems}">
												<Grid>
													<TextBlock Text="{DynamicResource LangText_ShowMore}" IsVisible="{Binding IsItemsExpanded, Converter={StaticResource NotConverter}}" />
													<TextBlock Text="{DynamicResource LangText_ShowLess}" IsVisible="{Binding IsItemsExpanded}" />
												</Grid>
											</Button>
										</StackPanel>
									</Expander>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
					<TextBlock Text="{DynamicResource LangText_SystemItems}" FontSize="13" FontWeight="SemiBold" Margin="8,16,8,4" />
					<StackPanel>
						<!-- loading indicator 已移至 TabControl 外层浮动覆盖 -->
						<Border Background="#10000000" CornerRadius="4" Padding="24,20"
								IsVisible="{Binding BlockedSystemItems, Converter={StaticResource CollectionEmptyConverter}}">
							<TextBlock Text="{DynamicResource LangText_NoData}" Foreground="Gray" HorizontalAlignment="Center" />
						</Border>
						<ItemsControl ItemsSource="{Binding BlockedSystemItems}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="models:SystemShellGroup">
									<Expander HorizontalAlignment="Stretch" IsExpanded="True" Margin="0,4" Padding="0" CornerRadius="4">
										<Expander.Header>
											<Grid ColumnDefinitions="Auto,*,Auto" MinHeight="48">
												<TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0" />
												<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0,12,0">
<CheckBox IsThreeState="True" IsChecked="{Binding SelectAllState, Mode=OneWay}" Command="{Binding SelectAllCommand}" VerticalAlignment="Center" />
									<Button Content="{DynamicResource LangText_EnableSelected}" Command="{Binding EnableSelectedCommand}" />
									<Button Content="{DynamicResource LangText_DisableSelected}" Command="{Binding DisableSelectedCommand}" />
												</StackPanel>
											</Grid>
										</Expander.Header>
										<StackPanel>
											<ItemsControl ItemsSource="{Binding VisibleItems}" Margin="40,8,12,8">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="models:SystemShellItem">
														<CheckBox Margin="0,4,0,4" IsChecked="{Binding Enabled, Mode=TwoWay}" IsEnabled="{Binding CanModify}">
															<CheckBox.ContextMenu>
																<ContextMenu>
																	<MenuItem Header="{DynamicResource LangText_OpenFileLocation}" Command="{Binding OpenFileLocationCommand}" IsEnabled="{Binding HasFilePath}" />
																</ContextMenu>
															</CheckBox.ContextMenu>
															<Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding DisplayName}" FontFamily="Consolas, Segoe UI" TextWrapping="Wrap" VerticalAlignment="Center" /><Border Grid.Column="1" Width="8" Height="8" CornerRadius="4" Background="{Binding StatusColor}" VerticalAlignment="Center" Margin="8,0,0,0" /></Grid>
														</CheckBox>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<Button HorizontalAlignment="Left" Margin="50,0,12,8"
													Command="{Binding ToggleItemsExpandCommand}" IsVisible="{Binding HasMoreItems}">
												<Grid>
													<TextBlock Text="{DynamicResource LangText_ShowMore}" IsVisible="{Binding IsItemsExpanded, Converter={StaticResource NotConverter}}" />
													<TextBlock Text="{DynamicResource LangText_ShowLess}" IsVisible="{Binding IsItemsExpanded}" />
												</Grid>
											</Button>
										</StackPanel>
									</Expander>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
					</StackPanel>
				</ScrollViewer>
			</TabItem>

			<!-- ════ Pending Tab ════ -->
			<TabItem Header="{DynamicResource LangText_TabPending}">
				<ScrollViewer Focusable="True" FocusAdorner="{x:Null}">
					<StackPanel>
					<TextBlock Text="{DynamicResource LangText_AppItems}" FontSize="13" FontWeight="SemiBold" Margin="8,8,8,4" />
					<StackPanel>
						<!-- loading indicator 已移至 TabControl 外层浮动覆盖 -->
						<Border Background="#10000000" CornerRadius="4" Padding="24,20"
								IsVisible="{Binding InterceptedApps, Converter={StaticResource CollectionEmptyConverter}}">
							<TextBlock Text="{DynamicResource LangText_NoData}" Foreground="Gray" HorizontalAlignment="Center" />
						</Border>
						<ItemsControl ItemsSource="{Binding InterceptedApps}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="models:PackagedAppModel">
									<Expander HorizontalAlignment="Stretch" IsExpanded="True" Margin="0,4" Padding="0" CornerRadius="4">
										<Expander.Header>
											<Grid ColumnDefinitions="Auto,*,Auto" MinHeight="60">
												<Border ClipToBounds="True" Width="32" Height="32" Margin="0,0,12,0" CornerRadius="4" Background="{DynamicResource AppListIconBackgroundBrush}" VerticalAlignment="Center">
													<Image Source="{Binding Icon}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="Uniform" />
												</Border>
												<TextBlock Text="{Binding DisplayName}" FontSize="14" LineHeight="22" Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,4" />
												<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0,12,0">
<CheckBox IsThreeState="True" IsChecked="{Binding SelectAllState, Mode=OneWay}" Command="{Binding SelectAllCommand}" VerticalAlignment="Center" />
									<Button Content="{DynamicResource LangText_EnableSelected}" Command="{Binding EnableSelectedCommand}" />
									<Button Content="{DynamicResource LangText_DisableSelected}" Command="{Binding DisableSelectedCommand}" />
												</StackPanel>
											</Grid>
										</Expander.Header>
										<StackPanel>
											<ItemsControl ItemsSource="{Binding VisibleContextMenuItems}" Margin="60,8,12,8">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="models:ContextMenuItemCheckModel">
														<CheckBox Margin="0,4,0,4" IsChecked="{Binding Enabled,Mode=TwoWay}" IsEnabled="{Binding CanModify}">
															<CheckBox.ContextMenu>
																<ContextMenu>
																	<MenuItem Header="{DynamicResource LangText_OpenFileLocation}" Command="{Binding OpenFileLocationCommand}" IsEnabled="{Binding HasFilePath}" />
																</ContextMenu>
															</CheckBox.ContextMenu>
															<Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding DisplayName}" FontFamily="Consolas, Segoe UI" TextWrapping="Wrap" VerticalAlignment="Center" /><Border Grid.Column="1" Width="8" Height="8" CornerRadius="4" Background="{Binding StatusColor}" VerticalAlignment="Center" Margin="8,0,0,0" /></Grid>
														</CheckBox>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<Button HorizontalAlignment="Left" Margin="70,0,12,8"
													Command="{Binding ToggleItemsExpandCommand}" IsVisible="{Binding HasMoreItems}">
												<Grid>
													<TextBlock Text="{DynamicResource LangText_ShowMore}" IsVisible="{Binding IsItemsExpanded, Converter={StaticResource NotConverter}}" />
													<TextBlock Text="{DynamicResource LangText_ShowLess}" IsVisible="{Binding IsItemsExpanded}" />
												</Grid>
											</Button>
										</StackPanel>
									</Expander>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
					<TextBlock Text="{DynamicResource LangText_SystemItems}" FontSize="13" FontWeight="SemiBold" Margin="8,16,8,4" />
					<StackPanel>
						<!-- loading indicator 已移至 TabControl 外层浮动覆盖 -->
						<Border Background="#10000000" CornerRadius="4" Padding="24,20"
								IsVisible="{Binding InterceptedSystemItems, Converter={StaticResource CollectionEmptyConverter}}">
							<TextBlock Text="{DynamicResource LangText_NoData}" Foreground="Gray" HorizontalAlignment="Center" />
						</Border>
						<ItemsControl ItemsSource="{Binding InterceptedSystemItems}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="models:SystemShellGroup">
									<Expander HorizontalAlignment="Stretch" IsExpanded="True" Margin="0,4" Padding="0" CornerRadius="4">
										<Expander.Header>
											<Grid ColumnDefinitions="Auto,*,Auto" MinHeight="48">
												<TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0" />
												<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0,12,0">
<CheckBox IsThreeState="True" IsChecked="{Binding SelectAllState, Mode=OneWay}" Command="{Binding SelectAllCommand}" VerticalAlignment="Center" />
									<Button Content="{DynamicResource LangText_EnableSelected}" Command="{Binding EnableSelectedCommand}" />
									<Button Content="{DynamicResource LangText_DisableSelected}" Command="{Binding DisableSelectedCommand}" />
												</StackPanel>
											</Grid>
										</Expander.Header>
										<StackPanel>
											<ItemsControl ItemsSource="{Binding VisibleItems}" Margin="40,8,12,8">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="models:SystemShellItem">
														<CheckBox Margin="0,4,0,4" IsChecked="{Binding Enabled, Mode=TwoWay}" IsEnabled="{Binding CanModify}">
															<CheckBox.ContextMenu>
																<ContextMenu>
																	<MenuItem Header="{DynamicResource LangText_OpenFileLocation}" Command="{Binding OpenFileLocationCommand}" IsEnabled="{Binding HasFilePath}" />
																</ContextMenu>
															</CheckBox.ContextMenu>
															<Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding DisplayName}" FontFamily="Consolas, Segoe UI" TextWrapping="Wrap" VerticalAlignment="Center" /><Border Grid.Column="1" Width="8" Height="8" CornerRadius="4" Background="{Binding StatusColor}" VerticalAlignment="Center" Margin="8,0,0,0" /></Grid>
														</CheckBox>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<Button HorizontalAlignment="Left" Margin="50,0,12,8"
													Command="{Binding ToggleItemsExpandCommand}" IsVisible="{Binding HasMoreItems}">
												<Grid>
													<TextBlock Text="{DynamicResource LangText_ShowMore}" IsVisible="{Binding IsItemsExpanded, Converter={StaticResource NotConverter}}" />
													<TextBlock Text="{DynamicResource LangText_ShowLess}" IsVisible="{Binding IsItemsExpanded}" />
												</Grid>
											</Button>
										</StackPanel>
									</Expander>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			</TabControl>
			<!-- ══ 单个共享 Lottie，浮动覆盖在所有 Tab 之上，仅加载时可见 ══ -->
			<lottie:Lottie Path="avares://RightClickManager/Assets/loading.json"
						   Width="64" Height="64"
						   HorizontalAlignment="Center" VerticalAlignment="Center"
						   IsVisible="{Binding SearchCommand.IsRunning}"
						   IsHitTestVisible="False" />
		</Grid>
	</Grid>
</Window>
