<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="LangText_AppTitle">右键菜单管理器</system:String>
    <system:String x:Key="LangText_ShowMainWindow">显示主界面</system:String>
    <system:String x:Key="LangText_ExitApp">完全退出</system:String>
    <system:String x:Key="LangText_Settings">设置</system:String>
    <system:String x:Key="LangText_AutoStart">开机自启</system:String>
    <system:String x:Key="LangText_Language">语言</system:String>
    <system:String x:Key="LangText_FollowSystem">跟随系统</system:String>
    <system:String x:Key="LangText_SearchWatermark">在此输入应用名称或 GUID 以进行搜索</system:String>
    <system:String x:Key="LangText_Search">搜索</system:String>
    <system:String x:Key="LangText_Refresh">刷新</system:String>
    <system:String x:Key="LangText_TabAllApps">全部应用</system:String>
    <system:String x:Key="LangText_TabBlockedApps">已拦截</system:String>
    <system:String x:Key="LangText_TabInterceptedApps">新增项记录</system:String>
    <system:String x:Key="LangText_NoData">暂无数据</system:String>
    <system:String x:Key="LangText_Allow">允许</system:String>
    <system:String x:Key="LangText_Block">拦截</system:String>
    <system:String x:Key="LangText_TabAllowed">已允许菜单</system:String>
    <system:String x:Key="LangText_TabDisabled">已禁用菜单</system:String>
    <system:String x:Key="LangText_TabPending">拦截待审核</system:String>
    <system:String x:Key="LangText_EnableAll">全部启用</system:String>
    <system:String x:Key="LangText_DisableAll">全部禁用</system:String>
    <system:String x:Key="LangText_InterceptedTitle">拦截提醒</system:String>
    <system:String x:Key="LangText_InterceptedMsg">检测到新添加的右键菜单。已自动拦截，请前往主界面审核。</system:String>
    <system:String x:Key="LangText_InterceptedVerbMsg">检测到新的 Shell 动词菜单项并已自动拦截。</system:String>
    <system:String x:Key="LangText_SystemItems">系统级右键菜单项</system:String>
</ResourceDictionary>
